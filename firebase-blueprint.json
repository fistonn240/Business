{
  "entities": {
    "Goal": {
      "title": "Goal",
      "description": "A business or life goal to be achieved.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user ID who owns this goal." },
        "title": { "type": "string", "description": "The title of the goal." },
        "status": { "type": "string", "enum": ["completed", "in-progress", "pending"], "description": "The current status of the goal." },
        "category": { "type": "string", "description": "The category of the goal (e.g., Business, Life)." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the goal was created." }
      },
      "required": ["uid", "title", "status", "category", "createdAt"]
    },
    "StrategySection": {
      "title": "Strategy Section",
      "description": "A section of the business strategy canvas.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user ID who owns this strategy." },
        "sectionId": { "type": "string", "description": "The ID of the section (e.g., value-prop)." },
        "content": { "type": "string", "description": "The content of the strategy section." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "When the section was last updated." }
      },
      "required": ["uid", "sectionId", "content", "updatedAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A financial transaction record.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Owner ID." },
        "amount": { "type": "number", "description": "Transaction amount." },
        "currency": { "type": "string", "description": "Currency code (e.g. USD, EUR)." },
        "type": { "type": "string", "enum": ["deposit", "withdrawal", "transfer"], "description": "Type of transaction." },
        "status": { "type": "string", "enum": ["pending", "completed", "failed"], "description": "Transaction status." },
        "recipient": { "type": "string", "description": "Recipient address or ID." },
        "timestamp": { "type": "string", "format": "date-time", "description": "Transaction time." }
      },
      "required": ["uid", "amount", "currency", "type", "status", "timestamp"]
    },
    "Portfolio": {
      "title": "Portfolio",
      "description": "A summary of user assets.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Owner ID." },
        "totalValue": { "type": "number", "description": "Total value in USD." },
        "assets": { "type": "array", "description": "List of assets." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last update." }
      },
      "required": ["uid", "totalValue", "updatedAt"]
    }
  },
  "firestore": {
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Collection of institutional transactions."
    },
    "/portfolios/{userId}": {
      "schema": "Portfolio",
      "description": "User asset summaries."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles."
    }
  }
}
